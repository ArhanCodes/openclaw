#!/usr/bin/env bash
# Pre-commit secret scanner. Blocks commits that contain real-looking API
# keys before they're written to history.
#
# Install with:  git config core.hooksPath .githooks
# (or run install/security-setup.sh which does it for you)

set -e

found=0

# Scan only what's about to be committed (staged contents, not the working tree)
files=$(git diff --cached --name-only --diff-filter=ACM)
if [[ -z "$files" ]]; then exit 0; fi

# Use the staged blob, not the working file (handles partial-stage)
matches=$(git diff --cached -U0 -- $files | grep -E '^\+' | grep -nE \
    'sk-ant-api03-[A-Za-z0-9_-]{32,}|sk-ant-oat01-[A-Za-z0-9_-]{32,}|sk-proj-[A-Za-z0-9_-]{32,}|GOCSPX-[A-Za-z0-9_-]{16,}|1//0[A-Za-z0-9_-]{40,}' \
    || true)

if [[ -n "$matches" ]]; then
    echo "✗ Found likely API keys in staged changes:" >&2
    echo "$matches" | sed 's/^/    /' >&2
    echo >&2
    echo "  Refusing commit. Move the secret to:" >&2
    echo "    - macOS Keychain (security add-generic-password …)" >&2
    echo "    - launchctl setenv (for daemon env vars)" >&2
    echo "    - ~/.openclaw/agents/main/agent/auth-profiles.json (mode 600)" >&2
    echo >&2
    echo "  Override (NOT recommended):  git commit --no-verify" >&2
    exit 1
fi

exit 0
